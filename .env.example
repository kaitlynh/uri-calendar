# Copy this file to .env and fill in the real values.
# .env is gitignored and will not be committed.

# PostgreSQL connection string (used by parse_json.py, validate_pipeline.py, API)
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/uri_calendar

# Eventfrog API key (used by scrape_eventfrog.py)
EVENTFROG_API_KEY=

# OpenAI API key (used by open-ai.py for AI enrichment)
OPENAI_API_KEY=
